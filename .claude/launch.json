{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Web (Next.js)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "web",
      "port": 3000,
      "autoPort": false
    },
    {
      "name": "Mobile (Expo)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["expo", "start", "--clear"],
      "cwd": "mobile",
      "port": 8081
    },
    {
      "name": "Mobile iOS (Expo)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["expo", "start", "--ios"],
      "cwd": "mobile",
      "port": 8081
    },
    {
      "name": "Mobile Android (Expo)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["expo", "start", "--android"],
      "cwd": "mobile",
      "port": 8081
    }
  ]
}
