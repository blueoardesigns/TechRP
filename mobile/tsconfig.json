{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "types": ["jest"],
    "baseUrl": ".",
    "paths": {
      "@supabase/supabase-js": ["./node_modules/@supabase/supabase-js"],
      "@/*": ["./*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "__tests__/**"
  ]
}
